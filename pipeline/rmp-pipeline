# /etc/cron.d/rmp-pipeline
# Raise My Presence — Outreach Send Automation
#
# Managed by RMP-2 deploy workflow. Edit canonical source in vault at:
#   Local-Presence-Optimization/src/pipeline/rmp-pipeline
# Never edit /etc/cron.d/rmp-pipeline directly on Tencent.
#
# Schedule (UTC — each line hits ~9 AM local in the target market):
#   UK  08:00 UTC → 09:00 BST
#   US  13:00 UTC → 09:00 Eastern / 08:00 Central
#   AU  22:00 UTC → 08:00 Sydney (next local morning, same UTC day)
#
# Caps are cumulative across markets via UTC-date filter in pipeline.py:
#   UK batch adds 5   → cap at 5
#   US batch adds 10  → cap at 15
#   AU batch adds 5   → cap at 20  (global daily ceiling)
#
# MAILTO="" disables cron's default mail-on-output behavior.
# All alerts dispatched explicitly via alert_on_failure.py.
# Logs written to /var/log/rmp-cron/<market>-<YYYY-MM-DD>.log via tee in run_market.sh.
#
# Rollback: comment out the three send lines and reinstall.
# Full removal: rm /etc/cron.d/rmp-pipeline on Tencent.
#
# File format: standard /etc/cron.d/ system cron (user field required between timing and command).
# Must be mode 644, owned by root, no extension. Cron ignores files otherwise.

MAILTO=""
PATH=/usr/local/bin:/usr/bin:/bin

0 8  * * * root /root/audit-scanner/pipeline/run_market.sh uk 5  >/dev/null 2>&1
0 13 * * * root /root/audit-scanner/pipeline/run_market.sh us 15 >/dev/null 2>&1
0 22 * * * root /root/audit-scanner/pipeline/run_market.sh au 20 >/dev/null 2>&1
